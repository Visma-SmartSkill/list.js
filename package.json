{
  "name": "list.js",
  "version": "2.5.0",
  "description": "The perfect library for lists. Supports search, sort, filters and flexibility. Built to be invisible and work on existing HTML",
  "keywords": [
    "list",
    "search",
    "sort",
    "table",
    "dom",
    "html",
    "ui"
  ],
  "author": {
    "name": "Jonny Strömberg",
    "email": "jonny.stromberg@gmail.com",
    "url": "https://javve.com"
  },
  "homepage": "https://listjs.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Visma-SmartSkill/list.js.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Visma-SmartSkill/list.js/issues"
  },
  "dependencies": {
    "string-natural-compare": "^2.0.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "main": "dist/list.cjs.js",
  "module": "dist/list.esm.js",
  "unpkg": "dist/list.js",
  "browser": "dist/list.js",
  "exports": {
    "import": "./dist/list.esm.js",
    "require": "./dist/list.cjs.js"
  },
  "engines": {
    "node": ">=6.0.0"
  },
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "vitest",
    "test:unit:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "build": "vite build",
    "watch": "vite build --watch"
  },
  "npmName": "list.js",
  "npmFileMap": [
    {
      "basePath": "/dist/",
      "files": [
        "*.js",
        "*.js.map"
      ]
    }
  ]
}